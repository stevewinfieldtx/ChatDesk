# ChatDesk service env (set these on Railway)

# AI fallback (OpenRouter). Without a key, the AI replies with a safe canned message.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Zoom (per-tenant values live in tenants/<id>.json; these are app-level secrets).
# Create ONE Zoom Marketplace app (Team Chat + Chatbot). See README for scopes.
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# Verification token / secret for validating inbound Zoom event webhooks:
ZOOM_WEBHOOK_SECRET=

# Optional shared secret a rep dashboard / test tools must send to post replies:
REP_SHARED_SECRET=changeme
